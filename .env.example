# ============================================================
# AI Agent RAG - Environment Variables
# Copy this file to .env and fill in your actual keys
# ============================================================

# --- Google Gemini API (primary LLM) ---
GOOGLE_API_KEY=your_google_gemini_api_key_here

# --- OpenAI-compatible keys (optional: OpenCode / Zen) ---
# If using OpenCode or Zen API (OpenAI-compatible endpoints)
OPENAI_API_KEY=your_openai_or_zen_key_here
OPENAI_BASE_URL=https://opencode.ai/zen/v1   # Or https://api.openai.com/v1 for standard OpenAI
OPENAI_MODEL=minimax-m2.5-free               # Model ID for your provider

# --- LangSmith (tracing / observability) ---
# Get your keys at https://smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=aiagent-rag
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# --- Which LLM provider to use: "gemini" | "openai" | "groq" ---
LLM_PROVIDER=gemini

# --- Groq (High-speed Inference) ---
# Get your key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
